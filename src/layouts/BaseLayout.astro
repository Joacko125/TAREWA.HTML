---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
// Fuentes self-hosted (Fontsource, variables, font-display: swap)
import '@fontsource-variable/space-grotesk'; // Display / títulos
import '@fontsource-variable/inter';         // Cuerpo
import '@fontsource-variable/jetbrains-mono'; // Datos / specs / códigos
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Resistencias Eléctricas Industriales | TAREWA Argentina',
  description = 'TAREWA: fabricantes de resistencias eléctricas industriales en Morón, Buenos Aires. +60 años de experiencia y envíos a todo el país. Pedí tu presupuesto.',
  canonical = 'https://tarewa.com/',
  ogImage = 'https://tarewa.com/assets/logo.avif',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es-AR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="es_AR" />
  <meta property="og:site_name" content="TAREWA" />

  <!-- Twitter Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Schema JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "TAREWA",
    "description": "Fabricantes de resistencias eléctricas industriales con más de 60 años de experiencia.",
    "url": "https://tarewa.com",
    "logo": "https://tarewa.com/assets/logo.avif",
    "image": "https://tarewa.com/assets/logo.avif",
    "telephone": "+5491141937728",
    "email": "ventas@tarewa.com",
    "foundingDate": "1964",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Huaura 235",
      "addressLocality": "Morón",
      "addressRegion": "Buenos Aires",
      "postalCode": "1708",
      "addressCountry": "AR"
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "08:00",
      "closes": "16:30"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Resistencias Eléctricas",
      "itemListElement": [
        {"@type": "Offer","itemOffered": {"@type": "Product","name": "Resistencias Blindadas Industriales"}},
        {"@type": "Offer","itemOffered": {"@type": "Product","name": "Resistencias Tubulares Industriales"}},
        {"@type": "Offer","itemOffered": {"@type": "Product","name": "Resistencias tipo Zuncho Industriales"}},
        {"@type": "Offer","itemOffered": {"@type": "Product","name": "Sensores de Temperatura Industriales"}},
        {"@type": "Offer","itemOffered": {"@type": "Product","name": "Pantallas Infrarrojas Industriales"}},
        {"@type": "Offer","itemOffered": {"@type": "Product","name": "Resistencias Eléctricas Planas"}},
        {"@type": "Offer","itemOffered": {"@type": "Product","name": "Resistencias Suspendidas Industriales"}},
        {"@type": "Offer","itemOffered": {"@type": "Product","name": "Bancos de Carga Resistivos Industriales"}},
        {"@type": "Offer","itemOffered": {"@type": "Product","name": "Resistencias Eléctricas Especiales a Medida"}},
        {"@type": "Offer","itemOffered": {"@type": "Product","name": "Accesorios para Resistencias Eléctricas"}}
      ]
    },
    "sameAs": []
  })} />

  <link rel="icon" type="image/avif" href="/assets/favicon.avif" />
  <!-- Tipografías self-hosted (Fontsource) importadas en el frontmatter del layout -->
</head>
<body>

  <Header />

  <slot />

  <Footer />

  <!-- VOLVER ARRIBA -->
  <button class="back-to-top" id="backToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="Volver arriba">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="18 15 12 9 6 15"/>
    </svg>
  </button>

  <WhatsAppButton />

  <script is:inline>
    // Logo: fallback a texto si no existe assets/logo.png
    const logoImg = document.getElementById('nav-logo-img');
    const logoText = document.getElementById('nav-logo-text');
    if (logoImg) {
      logoImg.onerror = function() {
        logoImg.style.display = 'none';
        if (logoText) logoText.style.display = 'block';
      };
    }

    // Nav shrink on scroll
    const navbar = document.getElementById('navbar');
    const backToTop = document.getElementById('backToTop');
    window.addEventListener('scroll', () => {
      if (navbar) navbar.classList.toggle('scrolled', window.scrollY > 60);
      if (backToTop) backToTop.classList.toggle('visible', window.scrollY > 400);
    });

    // Hamburger menu
    const hamburger = document.getElementById('navHamburger');
    const mobilePanel = document.getElementById('navMobilePanel');

    function openMenu() {
      hamburger.classList.add('is-open');
      navbar.classList.add('nav-open');
      hamburger.setAttribute('aria-expanded', 'true');
      hamburger.setAttribute('aria-label', 'Cerrar menú');
      mobilePanel.setAttribute('aria-hidden', 'false');
    }

    function closeMenu() {
      hamburger.classList.remove('is-open');
      navbar.classList.remove('nav-open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Abrir menú');
      mobilePanel.setAttribute('aria-hidden', 'true');
    }

    if (hamburger && mobilePanel) {
      hamburger.addEventListener('click', () => {
        hamburger.classList.contains('is-open') ? closeMenu() : openMenu();
      });

      // Close on link click (smooth scroll + close)
      mobilePanel.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (navbar.classList.contains('nav-open') && !navbar.contains(e.target)) {
          closeMenu();
        }
      });

      // Close when resizing to desktop width
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 900) closeMenu();
      });
    }

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Fallback SVG para imágenes sin foto
    document.querySelectorAll('.producto-img').forEach(div => {
      const svg = div.querySelector('svg');
      if (svg) svg.style.display = 'block';
    });

    // Form submit
    function handleSubmit(e) {
      e.preventDefault();
      const btn = e.target.querySelector('.btn-form');
      btn.textContent = '¡Enviado!';
      btn.classList.add('is-sent');
      setTimeout(() => {
        btn.textContent = 'Enviar consulta';
        btn.classList.remove('is-sent');
        e.target.reset();
      }, 3000);
    }
    // Exponer la función al scope global para el atributo inline onsubmit
    window.handleSubmit = handleSubmit;
  </script>

</body>
</html>
