---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto | TAREWA — Pedí tu presupuesto sin cargo"
  description="Contactanos por WhatsApp, teléfono o formulario. Atención de lunes a viernes de 8 a 16:30 hs. Huaura 235, Morón, Buenos Aires."
  canonical="https://tarewa.com/contacto"
>
  <main class="inner-page">

    <header class="page-header reveal">
      <p class="section-label">Hablemos</p>
      <h1>Pedí tu <span>presupuesto</span></h1>
      <p>Contanos qué necesitás y te respondemos a la brevedad con el mejor precio.</p>
    </header>

    <section id="contacto">
      <div class="contacto-info">
        <div class="contacto-item reveal reveal-delay-3">
          <div class="contacto-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.22 2.18 2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.15a16 16 0 006 6l1.52-1.52a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 13.92v3z"/>
            </svg>
          </div>
          <div class="contacto-item-text">
            <strong>Teléfono</strong>
            <a href="tel:+5491141937728">11 4193-7728</a>
          </div>
        </div>

        <div class="contacto-item reveal reveal-delay-4">
          <div class="contacto-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div class="contacto-item-text">
            <strong>Email</strong>
            <a href="mailto:ventas@tarewa.com">ventas@tarewa.com</a>
          </div>
        </div>

        <div class="contacto-item reveal reveal-delay-5">
          <div class="contacto-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="contacto-item-text">
            <strong>Dirección</strong>
            <span>Huaura 235, Morón, Buenos Aires</span>
          </div>
        </div>

        <div class="contacto-horario reveal reveal-delay-6">
          <p><strong>Horario de atención:</strong><br>
          Lunes a viernes · 8:00 a 16:30 hs</p>
        </div>

        <a href="https://wa.me/5491141937728?text=Hola!%20Quiero%20pedir%20un%20presupuesto." target="_blank" rel="noopener" class="contacto-wa reveal">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.999 1.998C6.477 1.998 2 6.476 2 12c0 1.89.523 3.659 1.435 5.173L2 22l4.978-1.31C8.41 21.536 10.163 22 12 22c5.522 0 10-4.478 10-10S17.521 1.998 12 1.998zm0 18c-1.72 0-3.329-.476-4.703-1.302l-.337-.2-3.498.921.936-3.41-.22-.35A7.95 7.95 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z"/></svg>
          Escribinos por WhatsApp
        </a>
      </div>

      <div class="contacto-form reveal right">
        <form onsubmit="handleSubmit(event)">
          <div class="form-row">
            <div class="form-group">
              <label>Nombre</label>
              <input type="text" placeholder="Tu nombre" required />
            </div>
            <div class="form-group">
              <label>Empresa</label>
              <input type="text" placeholder="Tu empresa (opcional)" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Teléfono</label>
              <input type="tel" placeholder="Tu teléfono" />
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" placeholder="Tu email" required />
            </div>
          </div>
          <div class="form-group">
            <label>Producto de interés</label>
            <select>
              <option value="">Seleccioná un producto</option>
              <option>Resistencias blindadas</option>
              <option>Resistencias tubulares</option>
              <option>Resistencias de zuncho</option>
              <option>Sensores de temperatura</option>
              <option>Pirómetros y termostatos</option>
              <option>Resistencias especiales / a medida</option>
              <option>Pantallas infrarrojas</option>
              <option>Resistencias planas</option>
              <option>Resistencias suspendidas</option>
              <option>Bancos de carga resistivos</option>
              <option>Otro</option>
            </select>
          </div>
          <div class="form-group">
            <label>Mensaje</label>
            <textarea placeholder="Describí lo que necesitás: tipo de resistencia, tensión, potencia, dimensiones, cantidad..."></textarea>
          </div>
          <button type="submit" class="btn-form">Enviar consulta</button>
        </form>
      </div>
    </section>

    <!-- MAPA -->
    <section id="mapa">
      <iframe
        src="https://maps.google.com/maps?q=Huaura+235%2C+Mor%C3%B3n%2C+Buenos+Aires%2C+Argentina&hl=es&z=16&output=embed"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación TAREWA — Huaura 235, Morón, Buenos Aires">
      </iframe>
    </section>

  </main>
</BaseLayout>
