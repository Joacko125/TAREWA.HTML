---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>

  <!-- ══ HERO CON SLIDER ══ -->
  <!--
    FOTOS DEL SLIDER: poné tus fotos en la carpeta assets/ con estos nombres:
      assets/slide-1.jpg  → foto general del taller o de resistencias
      assets/slide-2.jpg  → foto de resistencias blindadas / tubulares
      assets/slide-3.jpg  → foto de sensores / pirómetros
      assets/slide-4.jpg  → foto del equipo o productos terminados
  -->
  <section id="hero">
    <div class="swiper hero-swiper">
      <div class="swiper-wrapper">
        <div class="swiper-slide slide-1"></div>
        <div class="swiper-slide slide-2"></div>
        <div class="swiper-slide slide-3"></div>
        <div class="swiper-slide slide-4"></div>
      </div>
      <div class="swiper-pagination"></div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>

    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>

    <div class="hero-content">
      <h1 class="hero-badge">Resistencias Industriales · Morón, Buenos Aires</h1>
      <div class="hero-title">
        El calor que<br>
        tu <span class="highlight">Industria</span><br>
        <span class="highlight-y">necesita</span>
      </div>
      <p class="hero-slogan">
        Fabricamos <strong>resistencias eléctricas industriales</strong> a medida.<br>
        <em>Calidad, precisión y entrega en todo el país.</em>
      </p>
      <div class="hero-buttons">
        <a href="#productos" class="btn-primary">Ver productos</a>
        <a href="/contacto" class="btn-secondary">Pedir presupuesto</a>
      </div>
    </div>

  </section>

  <!-- ══ PRODUCTOS ══ -->
  <section id="productos">
    <div class="productos-header">
      <div>
        <p class="section-label reveal">Catálogo</p>
        <h2 class="section-title reveal reveal-delay-1">Nuestros <span>productos</span></h2>
        <p class="section-subtitle reveal reveal-delay-2">
          Fabricamos resistencias industriales por pedido. Cada pieza se diseña según las necesidades específicas de tu proceso.
        </p>
      </div>
    </div>

    <div class="productos-grid">

      <!-- Resistencias Blindadas -->
      <div class="producto-card reveal reveal-delay-1">
        <div class="producto-img" id="img-blindada">
          <img src="/assets/producto-blindada.avif" alt="Resistencias Blindadas Industriales" loading="lazy" width="900" height="613"
               onerror="document.getElementById('img-blindada').classList.add('sin-foto'); this.remove()" />
