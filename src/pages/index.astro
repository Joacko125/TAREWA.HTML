---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Slideshow del hero: levantamos dinámicamente todas las slide-*.avif de
// public/assets (no hardcodeadas). Astro corre este frontmatter en build.
const slides = fs
  .readdirSync(path.resolve('public/assets'))
  .filter((f) => /^slide-\d+\.avif$/i.test(f))
  .sort((a, b) => parseInt(a.match(/\d+/)[0], 10) - parseInt(b.match(/\d+/)[0], 10))
  .map((f) => `/assets/${f}`);
---

<BaseLayout>

  <!-- ══ SLIDESHOW DE FONDO FIJO — capa detrás de todo el contenido ══ -->
  <div class="hero-bg" aria-hidden="true">
    {slides.map((src, i) => (
      <div class={`hero-slide${i === 0 ? ' is-active' : ''}`} style={`background-image:url(${src})`}></div>
    ))}
    <div class="hero-bg-overlay"></div>
  </div>

  <!-- ══ FONDO FIJO DE LA SECCIÓN RESUMEN — misma técnica que el slideshow del
       hero: capa position:fixed REAL (iOS-safe, sin background-attachment:fixed).
       Vive a 100vw×100vh detrás de todo (z-index:-1); las secciones vecinas
       opacas la tapan y sólo se descubre a través de la sección resumen (que se
       vuelve transparente). Toggle por IntersectionObserver (ver script abajo). ══ -->
  <div class="resumen-bg" aria-hidden="true">
    <div class="resumen-bg-img" style="background-image:url(/assets/fondo-resistencia.avif)"></div>
  </div>

  <!-- ══ HERO — tesis de marca sobre el slideshow incandescente ══ -->
  <section id="hero">
    <div class="filamento"></div>
    <div class="hero-inner wrap">
      <div class="hero-copy">
        <p class="eyebrow"><span class="brand-dot"></span> Est. 1964 · Morón, Buenos Aires</p>
        <h1 class="hero-title">El calor que tu <span class="ink">industria</span> necesita</h1>
        <p class="hero-lead">
          Diseñamos y fabricamos <strong>resistencias eléctricas industriales a medida</strong>.
          Sesenta años de ingeniería térmica, asesoramiento real y entrega a todo el país.
        </p>
        <div class="hero-actions">
          <a href="#contacto" class="btn btn-primary">Pedí tu cotización</a>
          <a href="/productos" class="btn btn-secondary">Ver productos</a>
        </div>
        <ul class="hero-specs">
          <li><span>+60</span> años de fábrica</li>
          <li><span>100%</span> industria argentina</li>
          <li><span>10+</span> líneas de producto</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ══ PRODUCTOS ══ -->
  <section id="productos">
    <div class="productos-header">
      <div>
        <p class="section-label reveal">Catálogo</p>
        <h2 class="section-title reveal reveal-delay-1">Nuestros <span>productos</span></h2>
        <p class="section-subtitle reveal reveal-delay-2">
          Fabricamos resistencias industriales por pedido. Cada pieza se diseña según las necesidades específicas de tu proceso.
        </p>
      </div>
    </div>

