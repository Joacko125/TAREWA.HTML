  <!-- Autoplay del slideshow del hero (crossfade). Sin controles manuales. -->
  <script is:inline>
    (function () {
      const slides = Array.from(document.querySelectorAll('.hero-bg .hero-slide'));
      if (slides.length < 2) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      let i = 0;
      setInterval(function () {
        slides[i].classList.remove('is-active');
        i = (i + 1) % slides.length;
        slides[i].classList.add('is-active');
      }, 5500);
    })();
  </script>

  <!-- El fondo fijo del hero se apaga al pasar la sección catálogo (productos):
       el efecto de imagen fija aplica sólo por encima de catálogo. -->
  <script is:inline>
    (function () {
      const heroBg = document.querySelector('.hero-bg');
      const hero = document.getElementById('hero');
      if (!heroBg || !hero || !('IntersectionObserver' in window)) return;
      new IntersectionObserver(function (entries) {
        heroBg.classList.toggle('is-past', !entries[0].isIntersecting);
      }, { threshold: 0 }).observe(hero);
    })();
  </script>

  <!-- Fondo fijo de la sección resumen: misma técnica que el hero. La capa
       fija (.resumen-bg) se enciende sólo mientras la sección intersecta el
       viewport y la sección se vuelve transparente para revelarla. Fuera de
       ese rango queda apagada (no se filtra por la ventana del hero). -->
  <script is:inline>
    (function () {
      const bg = document.querySelector('.resumen-bg');
      const sec = document.querySelector('.index-summary.seccion-fondo');
      if (!bg || !sec || !('IntersectionObserver' in window)) return;
      new IntersectionObserver(function (entries) {
        const visible = entries[0].isIntersecting;
        bg.classList.toggle('is-active', visible);
        sec.classList.toggle('is-bgfixed', visible);
      }, { threshold: 0 }).observe(sec);
    })();
  </script>

  <!-- Grilla de productos: carga escalonada por columna al entrar al viewport. -->
  <script is:inline>
    (function () {
      const grid = document.querySelector('.productos-grid');
      if (!grid) return;
      if (!('IntersectionObserver' in window)) { grid.classList.add('is-revealed'); return; }
      const obs = new IntersectionObserver(function (entries, o) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) { grid.classList.add('is-revealed'); o.disconnect(); }
        });
      }, { threshold: 0.15 });
      obs.observe(grid);
    })();
  </script>

