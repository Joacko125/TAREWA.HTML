---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const fmtFecha = (d: Date) =>
  d.toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<!-- TODO: agregar paginación, tags y RSS cuando haya más posts -->

<BaseLayout
  title="Blog | TAREWA — Notas técnicas sobre resistencias industriales"
  description="Artículos prácticos sobre resistencias eléctricas industriales, sensores y calefacción para la industria argentina."
  canonical="https://tarewa.com/blog"
>
  <main class="inner-page">

    <header class="page-header reveal">
      <p class="section-label">Notas técnicas</p>
      <h1>Blog <span>TAREWA</span></h1>
      <p>Apuntes prácticos sobre resistencias eléctricas industriales, sensores y procesos térmicos.</p>
    </header>

    <section class="blog-list">
      {posts.length === 0 ? (
        <p class="blog-empty">Próximamente publicaremos los primeros artículos.</p>
      ) : (
        <div class="blog-grid">
          {posts.map((post, i) => (
            <article class={`blog-card reveal reveal-delay-${(i % 6) + 1}`}>
              <time datetime={post.data.publishDate.toISOString().slice(0, 10)} class="blog-date">
                {fmtFecha(post.data.publishDate)}
              </time>
              <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <a class="blog-readmore" href={`/blog/${post.id}`}>
                Leer artículo
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </article>
          ))}
        </div>
      )}
    </section>

  </main>
</BaseLayout>

<style>
  .blog-list { padding: 4rem var(--gutter) var(--space-section); background: var(--papel); }
  .blog-empty { text-align: center; color: var(--acero); padding: 4rem 0; }
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 820px;
    margin: 0 auto;
  }
  .blog-card {
    background: var(--lino);
    border: 1px solid var(--linea);
    border-radius: var(--radius-sm);
    padding: 2.2rem 2.4rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.35s var(--ease), transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  .blog-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 2px;
    background: var(--filamento);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.4s var(--ease);
  }
  .blog-card:hover {
    border-color: var(--acero);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .blog-card:hover::after { transform: scaleY(1); }
  .blog-date {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rojo-tinta);
    margin-bottom: 0.8rem;
  }
  .blog-card h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin-bottom: 0.8rem;
  }
  .blog-card h2 a {
    color: var(--grafito);
    text-decoration: none;
    transition: color 0.25s var(--ease);
  }
  .blog-card h2 a:hover { color: var(--rojo-tinta); }
  .blog-card p {
    color: var(--acero);
    font-size: var(--fs-sm);
    line-height: 1.7;
    margin-bottom: 1.2rem;
  }
  .blog-readmore {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--rojo-tinta);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: gap 0.25s var(--ease), color 0.25s var(--ease);
  }
  .blog-readmore svg { width: 18px; height: 18px; }
  .blog-readmore:hover { color: var(--grafito); gap: 0.85rem; }
  @media (max-width: 900px), (orientation: landscape) and (max-height: 500px) {
    .blog-list { padding: 3rem var(--gutter) 5rem; }
    .blog-card { padding: 1.6rem 1.5rem; }
  }
</style>
