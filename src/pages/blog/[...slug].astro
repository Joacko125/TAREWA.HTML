---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmtFecha = (d: Date) =>
  d.toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<BaseLayout
  title={`${post.data.title} | Blog TAREWA`}
  description={post.data.description}
  canonical={`https://tarewa.com/blog/${post.id}`}
  ogImage={post.data.image ?? 'https://tarewa.com/assets/logo.avif'}
>
  <main class="inner-page">

    <article class="blog-post">
      <header class="blog-post-header">
        <p class="section-label">Notas técnicas</p>
        <h1>{post.data.title}</h1>
        <div class="blog-post-meta">
          <time datetime={post.data.publishDate.toISOString().slice(0, 10)}>
            {fmtFecha(post.data.publishDate)}
          </time>
          <span aria-hidden="true">·</span>
          <span>Por {post.data.author}</span>
        </div>
      </header>

      <div class="blog-post-content">
        <Content />
      </div>

      <footer class="blog-post-footer">
        <a class="blog-back" href="/blog">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          Volver al blog
        </a>
      </footer>
    </article>

  </main>
</BaseLayout>

<style>
  .blog-post {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem var(--gutter) var(--space-section);
  }
  .blog-post-header {
    margin-bottom: 3rem;
    padding-bottom: 2.2rem;
    border-bottom: 1px solid var(--linea);
  }
  .blog-post-header h1 {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.03em;
    margin: 0.7rem 0 1.2rem;
    color: var(--grafito);
  }
  .blog-post-meta {
    display: inline-flex;
    gap: 0.5rem;
    color: var(--acero);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.04em;
  }
  /* Cuerpo editorial: Inter, medida cómoda, ritmo amplio */
  .blog-post-content {
    color: var(--grafito);
    font-size: 1.125rem;
    line-height: 1.8;
  }
  .blog-post-content :global(p) {
    margin-bottom: 1.5rem;
    color: var(--grafito);
  }
  .blog-post-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    margin: 2.8rem 0 1rem;
    color: var(--grafito);
    letter-spacing: -0.02em;
  }
  .blog-post-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 2rem 0 0.8rem;
    color: var(--rojo-tinta);
    letter-spacing: -0.01em;
  }
  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    padding-left: 1.4rem;
    margin-bottom: 1.6rem;
  }
  .blog-post-content :global(li) {
    margin-bottom: 0.6rem;
    color: var(--grafito);
  }
  .blog-post-content :global(strong) { color: var(--grafito); font-weight: 600; }
  .blog-post-content :global(a) {
    color: var(--rojo-tinta);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.25s var(--ease);
  }
  .blog-post-content :global(a:hover) { color: var(--rojo-hover); }
  .blog-post-content :global(code) {
    background: var(--lino);
    border: 1px solid var(--linea);
    padding: 0.12rem 0.42rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  .blog-post-content :global(pre) {
    background: var(--grafito);
    color: var(--papel);
    padding: 1.2rem;
    border-radius: var(--radius);
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .blog-post-content :global(pre code) { background: transparent; border: 0; color: inherit; padding: 0; }
  .blog-post-content :global(blockquote) {
    border-left: 3px solid var(--amarillo);
    background: var(--lino);
    padding: 0.8rem 1.3rem;
    margin: 1.6rem 0;
    color: var(--acero);
    font-style: italic;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
  .blog-post-footer {
    margin-top: 3.5rem;
    padding-top: 2.2rem;
    border-top: 1px solid var(--linea);
  }
  .blog-back {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--rojo-tinta);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.25s var(--ease), gap 0.25s var(--ease);
  }
  .blog-back svg { width: 18px; height: 18px; }
  .blog-back:hover { color: var(--grafito); gap: 0.85rem; }
</style>
