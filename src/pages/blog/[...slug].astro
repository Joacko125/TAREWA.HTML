---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmtFecha = (d: Date) =>
  d.toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<BaseLayout
  title={`${post.data.title} | Blog TAREWA`}
  description={post.data.description}
  canonical={`https://tarewa.com/blog/${post.id}`}
  ogImage={post.data.image ?? 'https://tarewa.com/assets/logo.avif'}
>
  <main class="inner-page">

    <article class="blog-post">
      <header class="blog-post-header">
        <p class="section-label">Notas técnicas</p>
        <h1>{post.data.title}</h1>
        <div class="blog-post-meta">
          <time datetime={post.data.publishDate.toISOString().slice(0, 10)}>
            {fmtFecha(post.data.publishDate)}
          </time>
          <span aria-hidden="true">·</span>
          <span>Por {post.data.author}</span>
        </div>
      </header>

      <div class="blog-post-content">
        <Content />
      </div>

      <footer class="blog-post-footer">
        <a class="blog-back" href="/blog">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          Volver al blog
        </a>
      </footer>
    </article>

  </main>
</BaseLayout>

<style>
  .blog-post {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }
  .blog-post-header {
    text-align: center;
    margin-bottom: 3.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .blog-post-header h1 {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0.6rem 0 1.2rem;
    color: var(--blanco);
  }
  .blog-post-meta {
    display: inline-flex;
    gap: 0.5rem;
    color: var(--texto-suave);
    font-size: 0.85rem;
    letter-spacing: 0.03em;
  }
  .blog-post-content {
    color: var(--blanco);
    font-size: 1.05rem;
    line-height: 1.85;
  }
  .blog-post-content :global(p) {
    margin-bottom: 1.4rem;
    color: rgba(240,240,240,0.92);
  }
  .blog-post-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 800;
    margin: 2.8rem 0 1rem;
    color: var(--blanco);
    letter-spacing: -0.005em;
  }
  .blog-post-content :global(h3) {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 2rem 0 0.8rem;
    color: var(--amarillo);
  }
  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    padding-left: 1.4rem;
    margin-bottom: 1.6rem;
  }
  .blog-post-content :global(li) {
    margin-bottom: 0.6rem;
    color: rgba(240,240,240,0.92);
  }
  .blog-post-content :global(strong) { color: var(--blanco); font-weight: 700; }
  .blog-post-content :global(a) {
    color: var(--amarillo);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.3s;
  }
  .blog-post-content :global(a:hover) { color: var(--rojo); }
  .blog-post-content :global(code) {
    background: var(--gris-oscuro);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    font-size: 0.92em;
  }
  .blog-post-content :global(pre) {
    background: var(--gris-oscuro);
    padding: 1.2rem;
    border-radius: 4px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255,255,255,0.06);
  }
  .blog-post-content :global(blockquote) {
    border-left: 3px solid var(--amarillo);
    padding: 0.6rem 1.2rem;
    margin: 1.5rem 0;
    color: var(--texto-suave);
    font-style: italic;
  }
  .blog-post-footer {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    text-align: center;
  }
  .blog-back {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--amarillo);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.3s, gap 0.3s;
  }
  .blog-back svg { width: 18px; height: 18px; }
  .blog-back:hover { color: var(--rojo); gap: 0.85rem; }
</style>
