---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { catalogos } from '../../data/catalogos.js';

const fmtFecha = (iso) => {
  if (!iso) return '';
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' });
};
---

<BaseLayout
  title="Catálogos | TAREWA — Descargá los PDF oficiales"
  description="Descargá los catálogos en PDF de TAREWA: resistencias industriales, sensores, accesorios y más. Especificaciones técnicas, códigos y aplicaciones."
  canonical="https://tarewa.com/catalogos"
>
  <main class="inner-page">

    <header class="page-header reveal">
      <p class="section-label">Descargas</p>
      <h1>Catálogos para <span>descargar</span></h1>
      <p>Estos son los catálogos oficiales TAREWA en formato PDF. Hacé click en el botón para descargarlos a tu equipo.</p>
    </header>

    <section class="catalogos-section">
      {catalogos.length === 0 ? (
        <p class="catalogos-empty">Próximamente publicaremos catálogos para descarga.</p>
      ) : (
        <div class="catalogos-grid">
          {catalogos.map((c, i) => (
            <article class={`catalogo-card reveal reveal-delay-${(i % 6) + 1}`}>
              <div class="catalogo-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <text x="7" y="17" font-family="Inter, sans-serif" font-size="5" font-weight="900" fill="currentColor" stroke="none">PDF</text>
                </svg>
              </div>
              <div class="catalogo-body">
                {c.categoria && <span class="catalogo-cat">{c.categoria}</span>}
                <h2>{c.titulo}</h2>
                <p>{c.descripcion}</p>
                <div class="catalogo-meta">
                  <span>{fmtFecha(c.fecha)}</span>
                  <span aria-hidden="true">·</span>
                  <span>{c.tamano}</span>
                </div>
                <a class="catalogo-btn" href={c.archivo} download>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                  </svg>
                  Descargar PDF
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

  </main>
</BaseLayout>

<style>
  .catalogos-section {
    padding: 4rem var(--gutter) var(--space-section);
    background: var(--papel);
  }
  .catalogos-empty {
    text-align: center;
    color: var(--acero);
    font-size: var(--fs-base);
    padding: 4rem 0;
  }
  .catalogos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
    max-width: var(--maxw);
    margin: 0 auto;
  }
  .catalogo-card {
    background: var(--lino);
    border: 1px solid var(--linea);
    border-radius: var(--radius-sm);
    padding: 2rem;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    position: relative;
    overflow: hidden;
    transition: border-color 0.35s var(--ease), transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  .catalogo-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--filamento);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease);
  }
  .catalogo-card:hover {
    border-color: var(--acero);
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .catalogo-card:hover::after { transform: scaleX(1); }
  .catalogo-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--papel);
    border: 1px solid var(--linea);
    border-radius: var(--radius-sm);
    color: var(--rojo-tinta);
  }
  .catalogo-icon svg { width: 32px; height: 32px; }
  .catalogo-body { flex: 1; min-width: 0; }
  .catalogo-cat {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rojo-tinta);
    margin-bottom: 0.5rem;
  }
  .catalogo-body h2 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 0.55rem;
    line-height: 1.3;
    color: var(--grafito);
  }
  .catalogo-body p {
    font-size: var(--fs-sm);
    color: var(--acero);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .catalogo-meta {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--acero);
    margin-bottom: 1.2rem;
    letter-spacing: 0.02em;
  }
  .catalogo-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--rojo-tinta);
    color: #fff;
    text-decoration: none;
    padding: 0.7rem 1.3rem;
    border-radius: var(--radius);
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: background 0.25s var(--ease), transform 0.2s var(--ease);
  }
  .catalogo-btn:hover {
    background: var(--rojo-hover);
    transform: translateY(-1px);
  }
  .catalogo-btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  @media (max-width: 900px), (orientation: landscape) and (max-height: 500px) {
    .catalogos-section { padding: 3rem var(--gutter) 5rem; }
    .catalogo-card { flex-direction: column; gap: 1rem; padding: 1.5rem; }
  }
</style>
