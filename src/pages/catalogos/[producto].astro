---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { productos } from '../../data/productos.js';
import { contacto, whatsappLink } from '../../data/contacto.js';

export async function getStaticPaths() {
  return productos.map((p) => ({
    params: { producto: p.slug },
    props: { producto: p },
  }));
}

const { producto } = Astro.props;
const fotos = [1, 2, 3, 4]; // por convención: 1.jpg, 2.jpg, ...
const descBreve = producto.descripcion[0];
const waHref = whatsappLink(producto.whatsappTexto);
---

<BaseLayout
  title={`${producto.nombre} | Catálogos | TAREWA`}
  description={descBreve.slice(0, 160)}
  canonical={`https://tarewa.com/catalogos/${producto.slug}`}
>
  <main class="inner-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span aria-hidden="true">›</span>
      <a href="/catalogos">Catálogos</a>
      <span aria-hidden="true">›</span>
      <span class="breadcrumb-current">{producto.nombre}</span>
    </nav>

    <article class="producto-detalle">

      <header class="producto-detalle-header reveal">
        <p class="section-label">Catálogo · {producto.codigo}</p>
        <h1>{producto.nombre}</h1>
      </header>

      <div class="producto-detalle-grid">

        <!-- CARRUSEL MANUAL -->
        <div class="producto-carrusel" data-carrusel data-nombre={producto.nombre}>
          <div class="carrusel-viewport">
            <ul class="carrusel-track">
              {fotos.map((n, i) => (
                <li class={`carrusel-slide ${i === 0 ? 'is-active' : ''}`} data-slide={i}>
                  <img
                    src={`/assets/productos/${producto.slug}/${n}.jpg`}
                    alt={`${producto.nombre} — foto ${n}`}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    onerror="this.closest('.carrusel-slide').classList.add('sin-foto'); this.remove();"
                  />
                  <div class="carrusel-placeholder">
                    <span>{producto.nombre}</span>
                  </div>
                </li>
              ))}
            </ul>
            <button class="carrusel-flecha carrusel-flecha-prev" type="button" aria-label="Foto anterior">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="15 18 9 12 15 6"/>
              </svg>
            </button>
            <button class="carrusel-flecha carrusel-flecha-next" type="button" aria-label="Foto siguiente">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </button>
          </div>
          <ol class="carrusel-dots" role="tablist">
            {fotos.map((_, i) => (
              <li>
                <button
                  type="button"
                  class={`carrusel-dot ${i === 0 ? 'is-active' : ''}`}
                  data-dot={i}
                  aria-label={`Ir a la foto ${i + 1}`}
                />
              </li>
            ))}
          </ol>
        </div>

        <!-- DESCRIPCIÓN + CTA -->
        <div class="producto-detalle-body reveal right">
          <div class="producto-descripcion">
            {producto.descripcion.map(p => <p>{p}</p>)}
          </div>

          <a href={waHref} target="_blank" rel="noopener" class="producto-cta-wa">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.999 1.998C6.477 1.998 2 6.476 2 12c0 1.89.523 3.659 1.435 5.173L2 22l4.978-1.31C8.41 21.536 10.163 22 12 22c5.522 0 10-4.478 10-10S17.521 1.998 12 1.998zm0 18c-1.72 0-3.329-.476-4.703-1.302l-.337-.2-3.498.921.936-3.41-.22-.35A7.95 7.95 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z"/></svg>
            Consultar por WhatsApp
          </a>
          <p class="producto-cta-secundario">
            ¿Preferís llamar? <a href={`tel:${contacto.telefonoLink}`}>{contacto.telefonoDisplay}</a> · o escribinos a <a href={`mailto:${contacto.email}`}>{contacto.email}</a>
          </p>
        </div>

      </div>

      <a href="/catalogos" class="producto-back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12"/>
          <polyline points="12 19 5 12 12 5"/>
        </svg>
        Volver a Catálogos
      </a>
    </article>

  </main>
</BaseLayout>

<style>
  .breadcrumb {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 4rem 0;
    font-size: 0.78rem;
    color: var(--texto-suave);
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .breadcrumb a {
    color: var(--texto-suave);
    text-decoration: none;
    transition: color 0.3s;
  }
  .breadcrumb a:hover { color: var(--amarillo); }
  .breadcrumb-current { color: var(--blanco); font-weight: 600; }

  .producto-detalle {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 4rem 6rem;
  }
  .producto-detalle-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .producto-detalle-header h1 {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-top: 0.6rem;
    color: var(--blanco);
  }
  .producto-detalle-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* CARRUSEL */
  .producto-carrusel {
    width: 100%;
  }
  .carrusel-viewport {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--gris-oscuro);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 2px;
    overflow: hidden;
    touch-action: pan-y;
    user-select: none;
  }
  .carrusel-track {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    position: relative;
  }
  .carrusel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .carrusel-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  .carrusel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .carrusel-placeholder {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    background:
      linear-gradient(135deg, var(--gris-oscuro) 0%, var(--gris-medio) 100%);
  }
  .carrusel-placeholder span {
    color: var(--texto-suave);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    max-width: 18rem;
    line-height: 1.4;
  }
  .carrusel-slide.sin-foto .carrusel-placeholder { display: flex; }

  .carrusel-flecha {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background: rgba(13,13,13,0.7);
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--blanco);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s, transform 0.2s, border-color 0.3s;
    z-index: 2;
  }
  .carrusel-flecha:hover {
    background: var(--rojo);
    border-color: var(--rojo);
    transform: translateY(-50%) scale(1.08);
  }
  .carrusel-flecha svg { width: 22px; height: 22px; }
  .carrusel-flecha-prev { left: 0.8rem; }
  .carrusel-flecha-next { right: 0.8rem; }

  .carrusel-dots {
    list-style: none;
    margin: 1.2rem 0 0;
    padding: 0;
    display: flex;
    justify-content: center;
    gap: 0.55rem;
  }
  .carrusel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.3s, transform 0.2s;
  }
  .carrusel-dot:hover { background: rgba(255,255,255,0.5); }
  .carrusel-dot.is-active {
    background: var(--rojo);
    transform: scale(1.25);
  }

  /* CUERPO DESCRIPCIÓN */
  .producto-descripcion p {
    color: rgba(240,240,240,0.92);
    line-height: 1.8;
    margin-bottom: 1.2rem;
    font-size: 1rem;
  }
  .producto-cta-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--whatsapp);
    color: #fff;
    text-decoration: none;
    padding: 1rem 1.6rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 1rem;
    margin-top: 1rem;
    transition: background 0.3s, transform 0.2s;
  }
  .producto-cta-wa:hover { background: #1da851; transform: translateY(-2px); }
  .producto-cta-wa svg { width: 22px; height: 22px; }
  .producto-cta-secundario {
    margin-top: 1.5rem;
    color: var(--texto-suave);
    font-size: 0.88rem;
    line-height: 1.7;
  }
  .producto-cta-secundario a {
    color: var(--amarillo);
    text-decoration: none;
    font-weight: 700;
  }
  .producto-cta-secundario a:hover { color: var(--rojo); }

  .producto-back {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 4rem;
    color: var(--amarillo);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.3s, gap 0.3s;
  }
  .producto-back svg { width: 18px; height: 18px; }
  .producto-back:hover { color: var(--rojo); gap: 0.85rem; }

  @media (max-width: 900px), (orientation: landscape) and (max-height: 500px) {
    .breadcrumb { padding: 1.2rem 2rem 0; }
    .producto-detalle { padding: 2rem 2rem 5rem; }
    .producto-detalle-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .carrusel-flecha { width: 38px; height: 38px; }
    .carrusel-flecha svg { width: 18px; height: 18px; }
  }
</style>

<script is:inline>
  (function() {
    const carruseles = document.querySelectorAll('[data-carrusel]');
    carruseles.forEach((root) => {
      const slides = root.querySelectorAll('.carrusel-slide');
      const dots = root.querySelectorAll('.carrusel-dot');
      const prev = root.querySelector('.carrusel-flecha-prev');
      const next = root.querySelector('.carrusel-flecha-next');
      const viewport = root.querySelector('.carrusel-viewport');
      if (!slides.length) return;

      let actual = 0;
      const total = slides.length;

      function go(i) {
        actual = (i + total) % total;
        slides.forEach((s, idx) => s.classList.toggle('is-active', idx === actual));
        dots.forEach((d, idx) => d.classList.toggle('is-active', idx === actual));
      }

      prev && prev.addEventListener('click', () => go(actual - 1));
      next && next.addEventListener('click', () => go(actual + 1));
      dots.forEach((d) => {
        d.addEventListener('click', () => go(parseInt(d.dataset.dot, 10)));
      });

      // Teclado: flechas izq/der cuando el viewport tiene foco
      viewport.setAttribute('tabindex', '0');
      viewport.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') { e.preventDefault(); go(actual - 1); }
        if (e.key === 'ArrowRight') { e.preventDefault(); go(actual + 1); }
      });

      // Swipe en mobile
      let startX = 0;
      let startY = 0;
      let moviendo = false;
      viewport.addEventListener('touchstart', (e) => {
        const t = e.changedTouches[0];
        startX = t.clientX;
        startY = t.clientY;
        moviendo = true;
      }, { passive: true });
      viewport.addEventListener('touchend', (e) => {
        if (!moviendo) return;
        moviendo = false;
        const t = e.changedTouches[0];
        const dx = t.clientX - startX;
        const dy = t.clientY - startY;
        if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
          dx < 0 ? go(actual + 1) : go(actual - 1);
        }
      }, { passive: true });
    });
  })();
</script>
