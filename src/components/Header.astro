---
// Header global. Los anchors funcionan desde el index;
// desde otras páginas anteponen "/" para volver al index y hacer scroll.
import { productos } from '../data/productos.js';

const isHome = Astro.url.pathname === '/';
const heroHref = isHome ? '#hero' : '/';
const contactoHref = isHome ? '#contacto' : '/#contacto';
// Servicios dejó de ser página propia: ahora es la sección #servicios del index.
const serviciosHref = isHome ? '#servicios' : '/#servicios';

const navItems = [
  { label: 'Productos', href: '/productos', cta: false, dropdown: true },
  { label: 'Nosotros', href: '/nosotros', cta: false },
  { label: 'Servicios', href: serviciosHref, cta: false },
  { label: 'Catálogos', href: '/catalogos', cta: false },
  { label: 'Blog', href: '/blog', cta: false },
  { label: 'Contacto', href: contactoHref, cta: true },
];
---

<!-- NAV -->
<nav id="navbar">
  <!--
    LOGO: poné tu logo en assets/logo.avif
    Si no existe, muestra el texto TAREWA automáticamente.
  -->
  <a href={heroHref} class="nav-logo">
    <img src="/assets/logo.avif" alt="TAREWA" class="nav-logo-img" id="nav-logo-img" width="1174" height="648" />
    <span class="nav-logo-text" id="nav-logo-text">TAR<span>E</span>WA</span>
  </a>
  <div class="nav-logo-60">
    <img src="/assets/logo-60.avif" alt="60 años TAREWA" width="116" height="116" />
  </div>
  <ul class="nav-links">
    {navItems.map(item => (
      item.dropdown ? (
        <li class="has-dropdown">
          <a href={item.href} class="nav-dropdown-trigger" aria-haspopup="true">
            {item.label}
            <svg class="nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <ul class="nav-dropdown">
            {productos.map(p => (
              <li><a href={`/productos/${p.slug}`}>{p.nombre}</a></li>
            ))}
          </ul>
        </li>
      ) : (
        <li><a href={item.href} class={item.cta ? 'nav-cta' : ''}>{item.label}</a></li>
      )
    ))}
  </ul>
  <button class="nav-hamburger" id="navHamburger" aria-label="Abrir menú" aria-expanded="false">
    <span class="hb-bar"></span>
    <span class="hb-bar"></span>
    <span class="hb-bar"></span>
  </button>
  <div class="nav-mobile-panel" id="navMobilePanel" aria-hidden="true">
    <ul class="nav-mobile-links">
      {navItems.map(item => (
        <li><a href={item.href} class={item.cta ? 'nav-cta' : ''}>{item.label}</a></li>
      ))}
    </ul>
  </div>
</nav>
