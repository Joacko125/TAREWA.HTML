---
// Carrusel manual de hitos de la historia de TAREWA.
// Recibe un array de hitos: { anio, titulo, texto, imagen? }.
// Navegación: flechas izq/der, dots y swipe. SIN autoplay.
interface Hito {
  anio: string;
  titulo: string;
  texto: string;
  imagen?: string;
}
const { hitos = [] } = Astro.props as { hitos: Hito[] };
---

<div class="historia-carrusel" data-historia>

  <div class="historia-viewport">
    <ul class="historia-track">
      {hitos.map((h, i) => (
        <li class={`historia-slide ${i === 0 ? 'is-active' : ''}`} data-slide={i}>
          <div class="historia-imagen">
            {h.imagen ? (
              <img
                src={h.imagen}
                alt={`${h.anio} — ${h.titulo}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                onerror="this.closest('.historia-imagen').classList.add('sin-foto'); this.remove();"
              />
            ) : null}
            <div class="historia-imagen-placeholder">
              <span>{h.anio}</span>
            </div>
          </div>
          <div class="historia-texto">
            <p class="historia-anio">{h.anio}</p>
            <h3 class="historia-titulo">{h.titulo}</h3>
            <p class="historia-cuerpo">{h.texto}</p>
          </div>
        </li>
      ))}
    </ul>

    <button class="historia-flecha historia-flecha-prev" type="button" aria-label="Hito anterior">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="historia-flecha historia-flecha-next" type="button" aria-label="Hito siguiente">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </div>

  <ol class="historia-dots" role="tablist">
    {hitos.map((h, i) => (
      <li>
        <button
          type="button"
          class={`historia-dot ${i === 0 ? 'is-active' : ''}`}
          data-dot={i}
          aria-label={`Ir al hito de ${h.anio}: ${h.titulo}`}
        >
          <span>{h.anio}</span>
        </button>
      </li>
    ))}
  </ol>
</div>

<style>
  .historia-carrusel {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
  }
  .historia-viewport {
    position: relative;
    background: var(--papel);
    border: 1px solid var(--linea);
    border-radius: var(--radius-sm);
    overflow: hidden;
    min-height: 380px;
    touch-action: pan-y;
  }
  .historia-track {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    min-height: 380px;
  }
  .historia-slide {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 0;
    opacity: 0;
    transition: opacity 0.45s ease;
    pointer-events: none;
  }
  .historia-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* IMAGEN */
  .historia-imagen {
    position: relative;
    overflow: hidden;
    background: var(--lino);
  }
  .historia-imagen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .historia-imagen-placeholder {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--lino) 0%, var(--papel) 100%);
  }
  .historia-imagen-placeholder span {
    font-family: var(--font-mono);
    font-size: clamp(3rem, 7vw, 4.6rem);
    font-weight: 600;
    color: rgba(27,29,33,0.12);
    letter-spacing: 0.04em;
  }
  .historia-imagen.sin-foto .historia-imagen-placeholder { display: flex; }

  /* TEXTO */
  .historia-texto {
    padding: 2.5rem 2.5rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .historia-anio {
    font-family: var(--font-mono);
    font-size: clamp(2.2rem, 5vw, 3rem);
    font-weight: 600;
    color: var(--rojo-tinta);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 0.6rem;
  }
  .historia-titulo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
    color: var(--grafito);
  }
  .historia-cuerpo {
    font-size: var(--fs-sm);
    color: var(--acero);
    line-height: 1.75;
    margin: 0;
  }

  /* FLECHAS */
  .historia-flecha {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background: rgba(244,243,240,0.92);
    border: 1px solid var(--linea);
    color: var(--grafito);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.3s, transform 0.2s, border-color 0.3s, color 0.3s;
    z-index: 3;
  }
  .historia-flecha:hover {
    background: var(--rojo-tinta);
    border-color: var(--rojo-tinta);
    color: #fff;
    transform: translateY(-50%) scale(1.08);
  }
  .historia-flecha svg { width: 22px; height: 22px; }
  .historia-flecha-prev { left: 0.8rem; }
  .historia-flecha-next { right: 0.8rem; }

  /* DOTS */
  .historia-dots {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }
  .historia-dot {
    background: transparent;
    border: 1px solid var(--linea);
    color: var(--acero);
    padding: 0.35rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.3s, color 0.3s, border-color 0.3s;
  }
  .historia-dot:hover {
    color: var(--grafito);
    border-color: var(--acero);
  }
  .historia-dot.is-active {
    background: var(--rojo-tinta);
    border-color: var(--rojo-tinta);
    color: #fff;
  }

  @media (max-width: 800px), (orientation: landscape) and (max-height: 500px) {
    .historia-viewport { min-height: 0; }
    .historia-track { min-height: 0; }
    .historia-slide { grid-template-columns: 1fr; position: relative; }
    .historia-slide:not(.is-active) { display: none; }
    .historia-slide.is-active { display: grid; }
    .historia-imagen { aspect-ratio: 4 / 3; }
    .historia-texto { padding: 2rem 1.6rem 2.5rem; }
    .historia-flecha { width: 38px; height: 38px; }
    .historia-flecha svg { width: 18px; height: 18px; }
    .historia-flecha-prev { left: 0.5rem; }
    .historia-flecha-next { right: 0.5rem; }
  }
</style>

<script is:inline>
  (function() {
    const carruseles = document.querySelectorAll('[data-historia]');
    carruseles.forEach((root) => {
      const slides = root.querySelectorAll('.historia-slide');
      const dots = root.querySelectorAll('.historia-dot');
      const prev = root.querySelector('.historia-flecha-prev');
      const next = root.querySelector('.historia-flecha-next');
      const viewport = root.querySelector('.historia-viewport');
      if (!slides.length) return;

      let actual = 0;
      const total = slides.length;

      function go(i) {
        actual = (i + total) % total;
        slides.forEach((s, idx) => s.classList.toggle('is-active', idx === actual));
        dots.forEach((d, idx) => d.classList.toggle('is-active', idx === actual));
      }

      prev && prev.addEventListener('click', () => go(actual - 1));
      next && next.addEventListener('click', () => go(actual + 1));
      dots.forEach((d) => {
        d.addEventListener('click', () => go(parseInt(d.dataset.dot, 10)));
      });

      // Teclado
      viewport.setAttribute('tabindex', '0');
      viewport.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') { e.preventDefault(); go(actual - 1); }
        if (e.key === 'ArrowRight') { e.preventDefault(); go(actual + 1); }
      });

      // Swipe
      let startX = 0;
      let startY = 0;
      let moviendo = false;
      viewport.addEventListener('touchstart', (e) => {
        const t = e.changedTouches[0];
        startX = t.clientX;
        startY = t.clientY;
        moviendo = true;
      }, { passive: true });
      viewport.addEventListener('touchend', (e) => {
        if (!moviendo) return;
        moviendo = false;
        const t = e.changedTouches[0];
        const dx = t.clientX - startX;
        const dy = t.clientY - startY;
        if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
          dx < 0 ? go(actual + 1) : go(actual - 1);
        }
      }, { passive: true });
    });
  })();
</script>
